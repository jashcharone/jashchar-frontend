# ═══════════════════════════════════════════════════════════════
# JASHCHAR ERP - FRONTEND PRODUCTION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════
# 
# SECURITY WARNING: 
# - Never commit this file with real values
# - Copy to .env.production and fill with actual values
# - Add .env.production to .gitignore
# 
# Created: February 10, 2026
# ═══════════════════════════════════════════════════════════════

# API Configuration
VITE_API_URL=https://api.jashcharerp.com/api

# Supabase Configuration (Public Keys Only)
# Get from: https://app.supabase.com/project/[project-id]/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key-here

# App Configuration
VITE_APP_NAME=Jashchar ERP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# Organization Configuration
VITE_DEFAULT_ORG=demo
VITE_ORG_DETECTION=subdomain

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_PWA_OFFLINE=true

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEV_TOOLS=false

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_HOTJAR_ID=XXXXXXX

# Error Tracking (Optional)
VITE_SENTRY_DSN=your-sentry-dsn-here

# Domain Configuration
VITE_MAIN_DOMAIN=jashcharerp.com
VITE_API_DOMAIN=api.jashcharerp.com

# CDN Configuration (Optional)
VITE_CDN_URL=https://cdn.jashcharerp.com

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Session Configuration
VITE_SESSION_TIMEOUT=3600000
VITE_REMEMBER_ME_DURATION=604800000

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST:
# ═══════════════════════════════════════════════════════════════
# 
# [ ] Copy this file to .env.production
# [ ] Fill VITE_API_URL with production API URL
# [ ] Add Supabase URL and anon key (public key only)
# [ ] Configure analytics IDs
# [ ] Setup error tracking (Sentry)
# [ ] Verify all URLs use HTTPS
# [ ] Test build: npm run build
# 
# ═══════════════════════════════════════════════════════════════
