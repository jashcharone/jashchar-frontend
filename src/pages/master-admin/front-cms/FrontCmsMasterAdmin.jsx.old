import React, { useState, useEffect } from 'react';
import { useSearchParams } from 'react-router-dom';
import DashboardLayout from '@/components/DashboardLayout';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Button } from '@/components/ui/button';
import { useToast } from '@/components/ui/use-toast';
import { supabase } from '@/lib/customSupabaseClient';
import { Loader2 } from 'lucide-react';
import { seedCmsDemoData } from '@/utils/seedCmsDemoData';
import UnifiedFrontCmsEditor from '@/components/front-cms/UnifiedFrontCmsEditor';

const FrontCmsMasterAdmin = () => {
  const { toast } = useToast();
  const { tab } = useParams();
  const navigate = useNavigate();
  const [searchParams, setSearchParams] = useSearchParams();
  const [schools, setSchools] = useState([]);
  const [selectedSchoolId, setSelectedSchoolId] = useState(searchParams.get('school_id') || '');
  const [loadingSchools, setLoadingSchools] = useState(true);
  const [seeding, setSeeding] = useState(false);

  // Update selectedSchoolId when URL param changes
  useEffect(() => {
    const id = searchParams.get('school_id');
    if (id) {
      setSelectedSchoolId(id);
    }
  }, [searchParams]);

  // Update URL when selectedSchoolId changes (from dropdown)
  const handleSchoolChange = (newId) => {
    setSelectedSchoolId(newId);
    setSearchParams({ school_id: newId });
  };

  // Map route params to component
  const routeToComponent = {
    'website-settings': WebsiteSettingsTab,
    'menus': Menus,
    'pages': PagesTab,
    'gallery': GalleryTab,
    'news': NewsTab,
    'media': MediaManagerTab,
    'banners': BannersTab,
    // Extras
    'login-settings': SchoolLoginSettingsTab,
    'general-settings': GeneralSettingsTab,
    'layout': HomeLayoutTab,
    'events': EventsTab,
    'notices': NoticesTab,
  };

  const ActiveComponent = routeToComponent[tab] || WebsiteSettingsTab;

  useEffect(() => {
    const fetchSchools = async () => {
      try {
        const { data, error } = await supabase
          .from('schools')
          .select('id, name, status')
          .eq('status', 'Active')
          .eq('is_primary', true) // Only show Organizations (Primary Schools)
          .order('name');
        
        if (error) throw error;
        setSchools(data || []);
      } catch (error) {
        toast({ variant: 'destructive', title: 'Error', description: 'Failed to load schools' });
      } finally {
        setLoadingSchools(false);
      }
    };
    fetchSchools();
  }, [toast]);

  const handleSeedData = async () => {
    if (!selectedSchoolId) return;
    setSeeding(true);
    const result = await seedCmsDemoData(selectedSchoolId);
    setSeeding(false);
    if (result.success) {
      toast({ title: result.status === 'seeded' ? 'Data Seeded' : 'Data Exists', description: result.status === 'seeded' ? 'Demo content injected successfully.' : 'Settings already exist, skipped seeding.' });
      window.location.reload(); 
    } else {
      toast({ variant: 'destructive', title: 'Error', description: 'Seeding failed.' });
    }
  };

  const menuItems = [
    { id: 'website-settings', label: 'Website Settings', icon: Settings },
    { id: 'menus', label: 'Menus', icon: Menu },
    { id: 'pages', label: 'Pages', icon: FileText },
    { id: 'gallery', label: 'Gallery', icon: Image },
    { id: 'news', label: 'News', icon: Newspaper },
    { id: 'media', label: 'Media Manager', icon: FolderOpen },
    { id: 'banners', label: 'Banner Images', icon: ImageIcon },
  ];

  // If no school selected, show selector
  if (!selectedSchoolId) {
    return <SchoolSelector />;
  }

  return (
    <DashboardLayout>
      <div className="flex h-[calc(100vh-64px)]">
        {/* Sidebar */}
        <div className="w-64 bg-white border-r p-4 space-y-2 overflow-y-auto">
            <h2 className="text-lg font-bold mb-4 px-2 text-slate-800">Front CMS</h2>
            
            <Button 
                variant="outline" 
                className="w-full justify-start mb-4 text-red-600 border-red-200 hover:bg-red-50"
                onClick={() => {
                  setSearchParams({});
                  setSelectedSchoolId('');
                }}
            >
                <Globe className="mr-2 h-4 w-4" />
                Change School
            </Button>

            {menuItems.map(item => (
                <Button
                    key={item.id}
                    variant={tab === item.id || (!tab && item.id === 'website-settings') ? "secondary" : "ghost"}
                    className="w-full justify-start"
                    onClick={() => navigate(`/master-admin/front-cms/${item.id}?school_id=${selectedSchoolId}`)}
                >
                    <item.icon className="mr-2 h-4 w-4" />
                    {item.label}
                </Button>
            ))}
        </div>

        {/* Main Content */}
        <div className="flex-1 overflow-auto p-6 bg-slate-50">
            <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
            <div>
                <h1 className="text-2xl font-bold tracking-tight text-slate-900">
                    {menuItems.find(m => m.id === (tab || 'website-settings'))?.label || 'Front CMS Manager'}
                </h1>
                <p className="text-slate-500">Manage public websites for all schools.</p>
            </div>
            <div className="flex items-center gap-4">
                <div className="w-64">
                <Select value={selectedSchoolId} onValueChange={handleSchoolChange}>
                    <SelectTrigger className="bg-white">
                    <SelectValue placeholder="Select School" />
                    </SelectTrigger>
                    <SelectContent>
                    {schools.map(s => (
                        <SelectItem key={s.id} value={s.id}>{s.name}</SelectItem>
                    ))}
                    </SelectContent>
                </Select>
                </div>
                {selectedSchoolId && (
                <Button variant="outline" size="sm" onClick={handleSeedData} disabled={seeding}>
                    {seeding ? <Loader2 className="mr-2 h-4 w-4 animate-spin" /> : null}
                    Seed Demo Data
                </Button>
                )}
            </div>
            </div>

            {!selectedSchoolId ? (
            <Card className="bg-white border-dashed">
                <CardContent className="flex flex-col items-center justify-center py-12 text-center">
                <Globe className="h-12 w-12 text-slate-300 mb-4" />
                <h3 className="text-lg font-medium text-slate-900">No School Selected</h3>
                <p className="text-slate-500 max-w-sm mt-2">Please select a school from the dropdown above to manage its public website content.</p>
                </CardContent>
            </Card>
            ) : (
            <div className="bg-white rounded-lg border shadow-sm">
                <ActiveComponent schoolId={selectedSchoolId} />
            </div>
            )}
        </div>
      </div>
    </DashboardLayout>
  );
};

export default FrontCmsMasterAdmin;
