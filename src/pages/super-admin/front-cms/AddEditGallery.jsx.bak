import React, { useState, useEffect } from 'react';
import DashboardLayout from '@/components/DashboardLayout';
import { useParams, useNavigate } from 'react-router-dom';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { supabase } from '@/lib/customSupabaseClient';
import { useAuth } from '@/contexts/SupabaseAuthContext';
import { useToast } from '@/components/ui/use-toast';
import ReactQuill from 'react-quill';
import 'react-quill/dist/quill.snow.css';
import SEODetail from '@/components/front-cms/SEODetail';
import SidebarSetting from '@/components/front-cms/SidebarSetting';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Upload, Trash2 } from 'lucide-react';
import MediaSelectorModal from '@/components/front-cms/MediaSelectorModal';

const AddEditGallery = () => {
  const { galleryId } = useParams();
  const navigate = useNavigate();
  const { user } = useAuth();
  const { toast } = useToast();
  const [loading, setLoading] = useState(false);
  const [modalOpen, setModalOpen] = useState(false);
  const [selectingFeatured, setSelectingFeatured] = useState(false); // Distinguish between featured img and gallery imgs
  
  const [formData, setFormData] = useState({
    title: '', description: '',
    meta_title: '', meta_keyword: '', meta_description: '',
    sidebar_enabled: false, featured_image: '', images: []
  });

  useEffect(() => {
    if (galleryId && user?.profile?.school_id) {
      const fetchGallery = async () => {
        const { data } = await supabase.from('cms_gallery').select('*').eq('id', galleryId).single();
        if (data) setFormData({ ...data, images: data.images || [] });
      };
      fetchGallery();
    }
  }, [galleryId, user]);

  const handleSave = async () => {
    if (!formData.title) return toast({ variant: 'destructive', title: 'Title required' });
    setLoading(true);
    try {
      const payload = { ...formData, school_id: user.profile.school_id };
      const query = galleryId 
        ? supabase.from('cms_gallery').update(payload).eq('id', galleryId)
        : supabase.from('cms_gallery').insert(payload);
      
      const { error } = await query;
      if (error) throw error;
      
      toast({ title: 'Saved successfully' });
      navigate('/school-owner/front-cms/gallery');
    } catch (error) {
      toast({ variant: 'destructive', title: 'Error saving' });
    } finally {
      setLoading(false);
    }
  };

  const handleMediaSelect = (files) => {
    if (selectingFeatured) {
      setFormData(prev => ({ ...prev, featured_image: files.file_url }));
    } else {
      const newImages = Array.isArray(files) ? files.map(f => f.file_url) : [files.file_url];
      setFormData(prev => ({ ...prev, images: [...(prev.images || []), ...newImages] }));
    }
  };

  const removeImage = (index) => {
    setFormData(prev => ({ ...prev, images: prev.images.filter((_, i) => i !== index) }));
  };

  return (
    <DashboardLayout>
      <div className="p-6 flex gap-6 flex-col lg:flex-row">
        <div className="flex-1 space-y-6">
          <Card>
            <CardHeader><CardTitle>Gallery Details</CardTitle></CardHeader>
            <CardContent className="space-y-4">
              <div><Label>Title *</Label><Input value={formData.title} onChange={e => setFormData({...formData, title: e.target.value})} /></div>
              <div>
                <Label>Description</Label>
                <ReactQuill theme="snow" value={formData.description || ''} onChange={v => setFormData({...formData, description: v})} className="mt-2 h-48 mb-12" />
              </div>
              <div>
                <div className="flex items-center justify-between mb-2">
                  <Label>Gallery Images</Label>
                  <Button size="sm" variant="outline" onClick={() => { setSelectingFeatured(false); setModalOpen(true); }}>
                    <Upload className="mr-2 h-4 w-4" /> Add Images
                  </Button>
                </div>
                <div className="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-4 mt-4">
                  {formData.images?.map((img, idx) => (
                    <div key={idx} className="relative group aspect-square bg-gray-100 rounded overflow-hidden">
                      <img src={img} alt={`Gallery ${idx}`} className="w-full h-full object-cover" />
                      <Button 
                        variant="destructive" size="icon" className="absolute top-1 right-1 w-6 h-6 opacity-0 group-hover:opacity-100 transition-opacity"
                        onClick={() => removeImage(idx)}
                      >
                        <Trash2 className="h-3 w-3" />
                      </Button>
                    </div>
                  ))}
                </div>
              </div>
            </CardContent>
          </Card>
          <SEODetail data={formData} onChange={(k, v) => setFormData(prev => ({...prev, [k]: v}))} />
        </div>

        <div className="w-full lg:w-80 space-y-6">
          <SidebarSetting enabled={formData.sidebar_enabled} onChange={v => setFormData({...formData, sidebar_enabled: v})} />
          <Card>
            <CardHeader><CardTitle className="text-base">Featured Image</CardTitle></CardHeader>
            <CardContent>
              <div className="border-2 border-dashed rounded-lg p-4 text-center cursor-pointer hover:bg-gray-50" onClick={() => { setSelectingFeatured(true); setModalOpen(true); }}>
                {formData.featured_image ? (
                  <img src={formData.featured_image} alt="Featured" className="w-full h-auto rounded" />
                ) : (
                  <div className="flex flex-col items-center text-gray-500">
                    <Upload className="h-8 w-8 mb-2" />
                    <span className="text-xs">Select Image</span>
                  </div>
                )}
              </div>
            </CardContent>
          </Card>
          <Button className="w-full" onClick={handleSave} disabled={loading}>{loading ? 'Saving...' : 'Save Gallery'}</Button>
        </div>
      </div>
      <MediaSelectorModal 
        isOpen={modalOpen} 
        onClose={() => setModalOpen(false)} 
        onSelect={handleMediaSelect} 
        allowMultiple={!selectingFeatured}
      />
    </DashboardLayout>
  );
};

export default AddEditGallery;