            {/* ✅ Examinations */}
            <Route path={ROUTES.SCHOOL_OWNER.EXAM_GROUP} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><ExamGroup /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.EXAM_LIST} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><ExamList /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.EXAM_SCHEDULE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher', 'student', 'parent']} requiredModule="examinations"><ExamSchedule /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.EXAM_ATTENDANCE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><ExamAttendance /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.MARKS_ENTRY} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><MarksEntry /></ProtectedRoute>} />
