            <Route path={ROUTES.SCHOOL_OWNER.CBSE_ASSESSMENT} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><CbseAssessment /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CBSE_OBSERVATION} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><CbseObservation /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CBSE_OBSERVATION_PARAM} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><CbseObservationParameter /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CBSE_EXAM_GRADE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><CbseExamGrade /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ADD_EXAM_SUBJECTS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><AddExamSubjects /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ASSIGN_STUDENTS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><AssignStudents /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ENTER_MARKS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><EnterMarks /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.LINK_EXAM} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><LinkExam /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.GENERATE_RANK} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><GenerateRank /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.GENERATE_TEMPLATE_RANK} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><GenerateTemplateRank /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.MARKSHEET_TEMPLATE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><MarksheetTemplate /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.PRINT_MARKSHEET} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><PrintMarksheet /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.PRINT_MARKSHEET_GENERAL} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><PrintMarksheetGeneral /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.PRINT_ADMIT_CARD} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><PrintAdmitCard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.DESIGN_MARKSHEET} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><DesignMarksheet /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.DESIGN_ADMIT_CARD} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><DesignAdmitCard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.TEACHER_REMARKS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher']} requiredModule="examinations"><TeacherRemarks /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ASSIGN_OBSERVATION} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><AssignObservation /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CBSE_REPORTS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="examinations"><CbseReports /></ProtectedRoute>} />

            {/* ✅ Library */}
            <Route path={ROUTES.SCHOOL_OWNER.LIBRARY_BOOKS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'librarian']} requiredModule="library"><LibraryBooks /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.LIBRARY_BOOK_ISSUED} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'librarian']} requiredModule="library"><LibraryBookIssued /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.LIBRARY_MEMBERS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'librarian']} requiredModule="library"><LibraryMembers /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.LIBRARY_ISSUE_RETURN} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'librarian']} requiredModule="library"><LibraryIssueReturn /></ProtectedRoute>} />

            {/* ✅ Hostel */}
            <Route path={ROUTES.SCHOOL_OWNER.HOSTELS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="hostel"><Hostels /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.HOSTEL_ROOMS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="hostel"><HostelRooms /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ROOM_TYPES} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="hostel"><RoomTypes /></ProtectedRoute>} />

            {/* ✅ Transport */}
            <Route path={ROUTES.SCHOOL_OWNER.TRANSPORT_ROUTES} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><TransportRoutes /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.TRANSPORT_VEHICLES} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><TransportVehicles /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.PICKUP_POINTS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><PickupPoints /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ROUTE_PICKUP_POINT} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><RoutePickupPoint /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.ASSIGN_VEHICLE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><AssignVehicle /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.STUDENT_TRANSPORT_FEES} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><StudentTransportFees /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.TRANSPORT_FEES_MASTER} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="transport"><TransportFeesMaster /></ProtectedRoute>} />

            {/* ✅ Communicate */}
            <Route path={ROUTES.SCHOOL_OWNER.NOTICE_BOARD} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher', 'student', 'parent']} requiredModule="communicate"><NoticeBoard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SEND_EMAIL} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="communicate"><SendEmail /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SEND_SMS} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="communicate"><SendSms /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.COMPOSE_MESSAGE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="communicate"><ComposeMessage /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.EMAIL_SMS_LOG} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="communicate"><EmailSmsLog /></ProtectedRoute>} />

            {/* ✅ QR Attendance */}
            <Route path={ROUTES.SCHOOL_OWNER.QR_ATTENDANCE_SETTING} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="qr_code_attendance"><QrAttendanceSetting /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.QR_ATTENDANCE_SCAN} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="qr_code_attendance"><QrAttendanceScan /></ProtectedRoute>} />

            {/* ✅ System Settings */}
            <Route path={ROUTES.SCHOOL_OWNER.SETTINGS_GENERAL} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><GeneralSetting /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SETTINGS_ROLE_PERMISSION} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><AssignPermissionSchoolPage /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SETTINGS_PROFILE_UPDATE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><StudentProfileUpdateSettings /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SETTINGS_PRINT_HEADER} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><PrintHeaderFooter /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.SETTINGS_ONLINE_ADMISSION} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><OnlineAdmissionSetting /></ProtectedRoute>} />

            {/* ✅ School Owner Assign Permission (Deep Link) */}
            <Route path="/school-owner/system-settings/assign-permission" element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><AssignPermissionSchoolPage /></ProtectedRoute>} />
            <Route path="/school-owner/system-settings/assign-permission/:roleId" element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="system_settings"><AssignPermissionSchoolPage /></ProtectedRoute>} />

            {/* ✅ Front CMS - Specific routes first to avoid route conflicts */}
            <Route path="/school-owner/front-cms/menus/:menuId/items" element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="front_cms"><MenuItems /></ProtectedRoute>} />
            <Route path="/school-owner/front-cms/menus" element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="front_cms"><Menus /></ProtectedRoute>} />
            {/* Front CMS Editor - must be last to avoid catching /menus route */}
            <Route path="/school-owner/front-cms/:tab?" element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="front_cms"><FrontCmsSchoolOwner /></ProtectedRoute>} />

            {/* ✅ Homework */}
            <Route path={ROUTES.SCHOOL_OWNER.HOMEWORK_LIST} element={<ProtectedRoute allowedRoles={['school_owner', 'admin', 'teacher', 'student', 'parent']} requiredModule="homework"><HomeworkList /></ProtectedRoute>} />

            {/* ✅ Inventory */}
            <Route path={ROUTES.SCHOOL_OWNER.INV_ADD_ITEM} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><AddItem /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.INV_ADD_STOCK} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><AddItemStock /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.INV_ISSUE_ITEM} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><IssueItem /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.INV_CATEGORY} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><ItemCategory /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.INV_STORE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><ItemStore /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.INV_SUPPLIER} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="inventory"><ItemSupplier /></ProtectedRoute>} />

            {/* ✅ Certificate */}
            <Route path={ROUTES.SCHOOL_OWNER.CERT_TEMPLATES} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><CertificateTemplates /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_GENERATE} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><GenerateCertificate /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_HISTORY} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><CertificateHistory /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_STUDENT} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><StudentCertificate /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_GENERATE_ID} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><GenerateIDCard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_STAFF_ID} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><StaffIDCard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_GENERATE_STAFF_ID} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><GenerateStaffIDCard /></ProtectedRoute>} />
            <Route path={ROUTES.SCHOOL_OWNER.CERT_STUDENT_ID} element={<ProtectedRoute allowedRoles={['school_owner', 'admin']} requiredModule="certificate"><StudentIDCard /></ProtectedRoute>} />

            {/* ✅ Student Panel */}
            <Route path={ROUTES.STUDENT.PROFILE} element={<ProtectedRoute allowedRoles={['student']}><StudentPanelProfile /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.EDIT_PROFILE} element={<ProtectedRoute allowedRoles={['student']}><EditStudentPanelProfile /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.FEES} element={<ProtectedRoute allowedRoles={['student']}><StudentPanelFees /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.EXAM_SCHEDULE} element={<ProtectedRoute allowedRoles={['student']}><StudentExamSchedule /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.EXAM_RESULT} element={<ProtectedRoute allowedRoles={['student']}><StudentExamResult /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.HOSTEL_ROOMS} element={<ProtectedRoute allowedRoles={['student']}><StudentHostelRooms /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.TRANSPORT_ROUTES} element={<ProtectedRoute allowedRoles={['student']}><StudentTransportRoutes /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.ATTENDANCE} element={<ProtectedRoute allowedRoles={['student']}><StudentAttendanceView /></ProtectedRoute>} />
            <Route path={ROUTES.STUDENT.APPLY_LEAVE} element={<ProtectedRoute allowedRoles={['student', 'parent']}><ApplyLeave /></ProtectedRoute>} />

            {/* ✅ DYNAMIC NEW MODULES */}
            {NEW_MODULES.map((module) => (
              <>
                <Route 
                  key={module.key} 
                  path={module.route.path} 
                  element={
                    <ProtectedRoute allowedRoles={[module.role]} requiredModule={module.key}>
                      {module.route.element}
                    </ProtectedRoute>
                  } 
                />
                {module.sidebar?.submenu?.map((sub, idx) => (
                  <Route
                    key={`${module.key}-sub-${idx}`}
                    path={sub.path}
                    element={
                      <ProtectedRoute allowedRoles={[module.role]} requiredModule={module.key}>
                        <PlaceholderModule title={sub.title} moduleName={`${module.key}.${sub.path.split('/').filter(Boolean).pop()?.replace(/-/g, '_')}`} />
                      </ProtectedRoute>
                    }
                  />
                ))}
              </>
            ))}

            {/* ✅ Dynamic New Module Routes (Moved to bottom to prevent blocking) */}
            <Route path="/*" element={<NewModuleRoutes />} />

            {/* ✅ Fallback */}
            <Route path="*" element={<NotFound />} />
          </Routes>
          </Suspense>
        </PermissionProvider>
      </EnvStatusProvider>
    </RecoveryProvider>
  );
}

export default App;
